          "supports_temperature": false
        },
        "gpt-5.4-pro": {
          "context_window": 1050000,
          "max_output_tokens": 128000,
          "supports_temperature": false
        }
      }
    },
    "groq": {
      "name": "Groq",
      "api_type": "openai_compatible",
      "base_url": "https://api.groq.com/openai/v1",
